; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TicSim"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

PlayerData="*res://scripts/PlayerData.gd"
EconomyManager="*res://scripts/EconomyManager.gd"
FactionManager="*res://scripts/FactionManager.gd"
CaravanSystem="*res://scripts/CaravanSystem.gd"
ContractManager="*res://scripts/ContractManager.gd"

[gui]

theme/custom="res://assets/theme.tres"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
